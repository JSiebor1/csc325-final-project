<TableView fx:id="eventTable">
<columns>
<TableColumn fx:id="nameColumn" text="Event Name" />
<TableColumn fx:id="dateColumn" text="Date" />
<TableColumn fx:id="locationColumn" text="Location" />
</columns>
</TableView>

<TextField fx:id="nameField" promptText="Event name" />
<TextField fx:id="dateField" promptText="Event date (e.g., 2025-07-01)" />
<TextField fx:id="locationField" promptText="Location" />
<Button fx:id="addButton" text="Add Event" onAction="#handleAddEvent" />
